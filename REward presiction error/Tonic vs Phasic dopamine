T_PHASIC = np.linspace(0, 2000, 4000)     # ms — subsecond scale
T_TONIC  = np.linspace(0, 3600, 3600)     # seconds — 1 hour scale
 
 
def make_phasic_signal(tonic_level=0.5, n_events=4):
    """
    Phasic bursts on top of a tonic baseline.
    Tonic level suppresses peak amplitude via autoreceptors.
    """
    rng = np.random.default_rng(seed=42)
    sig = np.ones_like(T_PHASIC) * tonic_level * 0.3   # tonic floor
 
    event_times = [300, 700, 1200, 1700][:n_events]
    rpe_vals    = [0.9, 0.4, -0.3, 0.7][:n_events]   # mix of + and - RPEs
 
    for t_event, rpe in zip(event_times, rpe_vals):
        mask   = (T_PHASIC > t_event) & (T_PHASIC < t_event + 300)
        t_rel  = T_PHASIC[mask] - t_event
        # peak amplitude suppressed by high tonic (autoreceptor model)
        suppression = 1 - tonic_level * 0.55
        if rpe > 0:
            burst = rpe * suppression * np.exp(-t_rel / 80) * np.clip(t_rel / 20, 0, 1)
            sig[mask] += burst
        else:
            pause = abs(rpe) * 0.6 * np.exp(-t_rel / 120) * np.clip(t_rel / 30, 0, 1)
            sig[mask] -= pause
 
    sig += rng.normal(0, 0.015, len(sig))
    return np.clip(sig, 0, None)
 
 
def make_tonic_signal(environment='rich'):
    """
    Tonic DA level over 1 hour.
    Tracks average reward rate in the environment (Niv 2007).
    """
    rng = np.random.default_rng(seed=17)
    baselines = dict(rich=0.72, moderate=0.42, lean=0.18, depleted=0.08)
    base = baselines.get(environment, 0.42)
 
    sig  = np.ones_like(T_TONIC) * base
    # slow fluctuations (minutes timescale)
    for freq in [0.002, 0.005, 0.001]:
        sig += rng.uniform(0.02, 0.06) * np.sin(2 * np.pi * freq * T_TONIC + rng.uniform(0, np.pi))
 
    # environment transitions
    if environment == 'rich':
        sig[T_TONIC > 1800] *= 0.7   # reward rate drops halfway through
    elif environment == 'lean':
        sig[T_TONIC > 2400] *= 1.6   # unexpected richness late
 
    sig += rng.normal(0, 0.01, len(sig))
    return np.clip(sig, 0, None)
 
 
def make_inverted_u(receptor='D1'):
    """
    Performance (working memory, etc.) as function of DA level.
    Inverted-U: too little or too much DA impairs function.
    D1 and D2 receptors have different optimal points.
    """
    da_levels = np.linspace(0, 1, 200)
    if receptor == 'D1':
        # D1: optimal at moderate-high DA, steep fall at extremes
        perf = np.exp(-((da_levels - 0.65) ** 2) / (2 * 0.18 ** 2))
    else:
        # D2: optimal at lower DA, shallower curve
        perf = np.exp(-((da_levels - 0.35) ** 2) / (2 * 0.22 ** 2))
    return da_levels, perf
 
 
def make_receptor_kinetics():
    """
    D1 vs D2 response to a phasic burst —
    D1 is slower but sustains longer, D2 is fast and transient.
    """
    t   = np.linspace(0, 800, 800)
    d1  = 0.9 * (1 - np.exp(-t / 80)) * np.exp(-t / 350)  # slow on, slow off
    d2  = 0.7 * np.exp(-t / 60) * np.clip(t / 15, 0, 1)   # fast on, fast off
    return t, d1, d2
 
 
