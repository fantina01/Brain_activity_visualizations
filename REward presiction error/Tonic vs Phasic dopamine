def draw_phasic(env):
    ax_phasic.cla()
    ax_phasic.set_facecolor(PANEL)
    for sp in ax_phasic.spines.values(): sp.set_color(DIM); sp.set_linewidth(0.6)
 
    tl  = TONIC_VALS[env]
    sig = make_phasic_signal(tonic_level=tl)
 
    ax_phasic.fill_between(T_PHASIC, tl * 0.3, sig,
                            where=sig > tl * 0.3 + 0.05,
                            color=PHASIC, alpha=0.18)
    ax_phasic.fill_between(T_PHASIC, sig, tl * 0.3,
                            where=sig < tl * 0.3 - 0.02,
                            color='#3a86ff', alpha=0.18)
    ax_phasic.plot(T_PHASIC, sig, color=PHASIC, linewidth=1.6, label='Phasic DA signal')
    ax_phasic.axhline(tl * 0.3, color=TONIC, linewidth=1.2, linestyle='--',
                      alpha=0.7, label=f'Tonic floor  ({env})')
 
    ax_phasic.set_xlabel('Time (ms)', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_phasic.set_ylabel('DA concentration (norm.)', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_phasic.set_title('Phasic Signal — Subsecond Timescale',
                        color=WHITE, fontsize=9, fontfamily='monospace', pad=6)
    ax_phasic.tick_params(colors=TEXT, labelsize=7)
    ax_phasic.legend(fontsize=7, facecolor=BG, edgecolor=DIM, labelcolor=TEXT)
    ax_phasic.text(0.02, 0.92,
                   f'Peak amplitude suppressed\nby high tonic (autoreceptors)',
                   color=GREY, fontsize=6.5, fontfamily='monospace',
                   transform=ax_phasic.transAxes, va='top')
 
 
def draw_tonic(env):
    ax_tonic.cla()
    ax_tonic.set_facecolor(PANEL)
    for sp in ax_tonic.spines.values(): sp.set_color(DIM); sp.set_linewidth(0.6)
 
    for e, alpha in [('depleted', 0.25), ('lean', 0.35),
                     ('moderate', 0.45), ('rich', 0.55)]:
        sig = make_tonic_signal(e)
        lw  = 2.2 if e == env else 0.8
        a   = 1.0 if e == env else alpha * 0.5
        col = TONIC if e == env else GREY
        ax_tonic.plot(T_TONIC / 60, sig, color=col, linewidth=lw,
                      alpha=a, label=f'{e}' if e == env else None)
 
    ax_tonic.set_xlabel('Time (minutes)', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_tonic.set_ylabel('Tonic DA level', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_tonic.set_title('Tonic Signal — Minute–Hour Timescale',
                       color=WHITE, fontsize=9, fontfamily='monospace', pad=6)
    ax_tonic.tick_params(colors=TEXT, labelsize=7)
    ax_tonic.text(0.02, 0.92, f'Environment: {env}\n(avg reward rate → tonic DA)',
                  color=TONIC, fontsize=7, fontfamily='monospace',
                  transform=ax_tonic.transAxes, va='top')
 
 
def draw_interaction(env):
    ax_interact.cla()
    ax_interact.set_facecolor(PANEL)
    for sp in ax_interact.spines.values(): sp.set_color(DIM); sp.set_linewidth(0.6)
 
    # Show phasic signal under low vs high tonic — side by side
    tl_low  = TONIC_VALS['lean']
    tl_high = TONIC_VALS['rich']
    sig_low  = make_phasic_signal(tonic_level=tl_low)
    sig_high = make_phasic_signal(tonic_level=tl_high)
 
    ax_interact.plot(T_PHASIC, sig_low,  color=PHASIC, linewidth=1.8,
                     alpha=0.9, label='Phasic (low tonic background)')
    ax_interact.plot(T_PHASIC, sig_high, color=TONIC, linewidth=1.8,
                     alpha=0.9, label='Phasic (high tonic background)')
 
    ax_interact.axhline(tl_low  * 0.3, color=PHASIC, linewidth=0.8,
                        linestyle=':', alpha=0.5)
    ax_interact.axhline(tl_high * 0.3, color=TONIC, linewidth=0.8,
                        linestyle=':', alpha=0.5)
 
    ax_interact.set_xlabel('Time (ms)', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_interact.set_ylabel('DA signal', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_interact.set_title('Phasic × Tonic Interaction',
                          color=WHITE, fontsize=9, fontfamily='monospace', pad=6)
    ax_interact.tick_params(colors=TEXT, labelsize=7)
    ax_interact.legend(fontsize=7, facecolor=BG, edgecolor=DIM, labelcolor=TEXT)
    ax_interact.text(0.02, 0.10,
                     'High tonic suppresses phasic peaks\nvia D2 autoreceptors on DA terminals.',
                     color=GREY, fontsize=6.5, fontfamily='monospace',
                     transform=ax_interact.transAxes)
 
 
def draw_inverted_u():
    ax_invU.cla()
    ax_invU.set_facecolor(PANEL)
    for sp in ax_invU.spines.values(): sp.set_color(DIM); sp.set_linewidth(0.6)
 
    da_d1, p_d1 = make_inverted_u('D1')
    da_d2, p_d2 = make_inverted_u('D2')
 
    ax_invU.fill_between(da_d1, p_d1, alpha=0.10, color=D1)
    ax_invU.fill_between(da_d2, p_d2, alpha=0.10, color=D2)
    ax_invU.plot(da_d1, p_d1, color=D1, linewidth=2.0, label='D1 receptor function')
    ax_invU.plot(da_d2, p_d2, color=D2, linewidth=2.0, label='D2 receptor function')
 
    ax_invU.axvline(0.65, color=D1, linewidth=0.8, linestyle='--', alpha=0.5)
    ax_invU.axvline(0.35, color=D2, linewidth=0.8, linestyle='--', alpha=0.5)
 
    ax_invU.set_xlabel('DA level (tonic background)',
                       color=TEXT, fontsize=8, fontfamily='monospace')
    ax_invU.set_ylabel('Cognitive performance (norm.)',
                       color=TEXT, fontsize=8, fontfamily='monospace')
    ax_invU.set_title('Inverted-U: Optimal DA for Cognition',
                      color=WHITE, fontsize=9, fontfamily='monospace', pad=6)
    ax_invU.tick_params(colors=TEXT, labelsize=7)
    ax_invU.legend(fontsize=7, facecolor=BG, edgecolor=DIM, labelcolor=TEXT)
    ax_invU.text(0.02, 0.18,
                 'Too little or too much DA\nboth impair PFC function.\nSchizophrenia ↔ ADHD axis.',
                 color=GREY, fontsize=7, fontfamily='monospace',
                 transform=ax_invU.transAxes,
                 bbox=dict(boxstyle='round,pad=0.3', facecolor=BG,
                           edgecolor=DIM, linewidth=0.6))
 
 
def draw_kinetics():
    ax_kinetics.cla()
    ax_kinetics.set_facecolor(PANEL)
    for sp in ax_kinetics.spines.values(): sp.set_color(DIM); sp.set_linewidth(0.6)
 
    t, d1, d2 = make_receptor_kinetics()
 
    ax_kinetics.fill_between(t, d1, alpha=0.12, color=D1)
    ax_kinetics.fill_between(t, d2, alpha=0.12, color=D2)
    ax_kinetics.plot(t, d1, color=D1, linewidth=2.0,
                     label='D1 response  (slow, sustained)')
    ax_kinetics.plot(t, d2, color=D2, linewidth=2.0,
                     label='D2 response  (fast, transient)')
 
    ax_kinetics.axvline(0, color=PHASIC, linewidth=1.2, linestyle='--', alpha=0.6)
    ax_kinetics.text(8, 0.88, 'Phasic\nburst', color=PHASIC,
                     fontsize=7, fontfamily='monospace')
 
    ax_kinetics.set_xlabel('Time after phasic burst (ms)',
                           color=TEXT, fontsize=8, fontfamily='monospace')
    ax_kinetics.set_ylabel('Receptor activation (norm.)',
                           color=TEXT, fontsize=8, fontfamily='monospace')
    ax_kinetics.set_title('D1 vs D2 Receptor Kinetics',
                          color=WHITE, fontsize=9, fontfamily='monospace', pad=6)
    ax_kinetics.tick_params(colors=TEXT, labelsize=7)
    ax_kinetics.legend(fontsize=7, facecolor=BG, edgecolor=DIM, labelcolor=TEXT)
 
 
