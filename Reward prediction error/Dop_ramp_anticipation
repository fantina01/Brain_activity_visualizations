def draw_single(t_reward):
    ax_single.cla()
    ax_single.set_facecolor(PANEL)
    for sp in ax_single.spines.values(): sp.set_color(DIM); sp.set_linewidth(0.6)
 
    # show 5 individual neurons to give a sense of variability
    for i in range(5):
        t, sig = make_ramp(t_reward, noise_level=0.035, neuron_idx=i)
        alpha  = 0.35 + i * 0.06
        ax_single.plot(t, sig, color=GOLD, linewidth=0.9, alpha=alpha)
 
    # population mean on top
    t, avg, std = make_population_average(t_reward)
    ax_single.fill_between(t, avg - std * 0.5, avg + std * 0.5,
                            color=GOLD, alpha=0.12)
    ax_single.plot(t, avg, color=GOLD, linewidth=2.2, label='Population mean')
 
    # markers
    ax_single.axvline(T_CUE, color=TEAL, linewidth=1.4, linestyle='--', alpha=0.85)
    ax_single.axvline(t_reward, color=ORANGE, linewidth=1.4, linestyle='--', alpha=0.85)
    ax_single.text(T_CUE + 20, ax_single.get_ylim()[1] * 0.92,
                   'CUE', color=TEAL, fontsize=7, fontfamily='monospace')
    ax_single.text(t_reward + 20, ax_single.get_ylim()[1] * 0.92,
                   'REWARD', color=ORANGE, fontsize=7, fontfamily='monospace')
 
    ax_single.set_xlabel('Time (ms)', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_single.set_ylabel('DA signal (norm.)', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_single.set_title('Single Trial — DA Ramp (5 neurons + mean)',
                        color=WHITE, fontsize=9, fontfamily='monospace', pad=6)
    ax_single.tick_params(colors=TEXT, labelsize=7)
    ax_single.legend(fontsize=7, facecolor=BG, edgecolor=DIM, labelcolor=TEXT)
 
 
def draw_raster(t_reward):
    ax_raster.cla()
    ax_raster.set_facecolor(PANEL)
    for sp in ax_raster.spines.values(): sp.set_color(DIM); sp.set_linewidth(0.6)
 
    spikes_all = make_raster(t_reward)
 
    for i, spikes in enumerate(spikes_all):
        # color spikes by their timing: ramp period gets warmer color
        colors = []
        for s in spikes:
            if s < T_CUE + 80:
                colors.append(GREY)
            elif s < t_reward:
                # gradient along ramp: early=blue, late=gold
                frac = (s - T_CUE) / (t_reward - T_CUE)
                r = int(0x3a + frac * (0xf7 - 0x3a))
                g = int(0x86 + frac * (0xc9 - 0x86))
                b = int(0xff + frac * (0x48 - 0xff))
                colors.append(f'#{r:02x}{g:02x}{b:02x}')
            else:
                colors.append(ORANGE)
        ax_raster.vlines(spikes, i + 0.08, i + 0.88,
                         colors=colors, linewidth=0.85, alpha=0.9)
 
    ax_raster.axvline(T_CUE, color=TEAL, linewidth=1.2, linestyle='--', alpha=0.7)
    ax_raster.axvline(t_reward, color=ORANGE, linewidth=1.2, linestyle='--', alpha=0.7)
 
    ax_raster.set_xlim(-100, t_reward + 400)
    ax_raster.set_ylim(0, N_NEURONS)
    ax_raster.set_xlabel('Time (ms)', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_raster.set_ylabel('Neuron #  (NAc / VS)', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_raster.set_title('Spike Raster — Colour Encodes Ramp Phase',
                        color=WHITE, fontsize=9, fontfamily='monospace', pad=6)
    ax_raster.tick_params(colors=TEXT, labelsize=7)
 
    patches = [
        mpatches.Patch(color=BLUE,   label='Early ramp'),
        mpatches.Patch(color=GOLD,   label='Late ramp'),
        mpatches.Patch(color=ORANGE, label='Reward delivery'),
        mpatches.Patch(color=GREY,   label='Baseline'),
    ]
    ax_raster.legend(handles=patches, fontsize=6.5, ncol=2,
                     facecolor=BG, edgecolor=DIM, labelcolor=TEXT)
 
 
def draw_population(t_reward):
    ax_pop.cla()
    ax_pop.set_facecolor(PANEL)
    for sp in ax_pop.spines.values(): sp.set_color(DIM); sp.set_linewidth(0.6)
 
    t, avg, std = make_population_average(t_reward, n=N_NEURONS)
 
    ax_pop.fill_between(t, avg - std, avg + std, color=GOLD, alpha=0.10, label='±1 SD')
    ax_pop.fill_between(t, avg - std * 0.5, avg + std * 0.5,
                        color=GOLD, alpha=0.18, label='±0.5 SD')
    ax_pop.plot(t, avg, color=GOLD, linewidth=2.4, label=f'Mean  (n={N_NEURONS})')
 
    # fit a line to the ramp portion to show linearity
    ramp_mask = (t > 200) & (t < t_reward - 100)
    if ramp_mask.sum() > 5:
        coeffs  = np.polyfit(t[ramp_mask], avg[ramp_mask], 1)
        t_fit   = t[ramp_mask]
        ax_pop.plot(t_fit, np.polyval(coeffs, t_fit),
                    color=TEAL, linewidth=1.2, linestyle='--',
                    alpha=0.7, label=f'Linear fit  (slope={coeffs[0]*1000:.3f}/s)')
 
    ax_pop.axvline(T_CUE, color=TEAL, linewidth=1.3, linestyle='--', alpha=0.8)
    ax_pop.axvline(t_reward, color=ORANGE, linewidth=1.3, linestyle='--', alpha=0.8)
 
    ax_pop.set_xlabel('Time (ms)', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_pop.set_ylabel('Mean DA signal', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_pop.set_title(f'Population Average  (delay = {t_reward}ms)',
                     color=WHITE, fontsize=9, fontfamily='monospace', pad=6)
    ax_pop.tick_params(colors=TEXT, labelsize=7)
    ax_pop.legend(fontsize=7, facecolor=BG, edgecolor=DIM, labelcolor=TEXT)
 
 
def draw_timing_comparison():
    ax_timing.cla()
    ax_timing.set_facecolor(PANEL)
    for sp in ax_timing.spines.values(): sp.set_color(DIM); sp.set_linewidth(0.6)
 
    colors  = [BLUE, GOLD, ORANGE]
    results = make_timing_comparison()
 
    for (td, (t_norm, avg, std)), col in zip(results.items(), colors):
        # only plot up to reward (t_norm <= 1)
        mask = t_norm <= 1.02
        ax_timing.fill_between(t_norm[mask], (avg - std * 0.4)[mask],
                               (avg + std * 0.4)[mask], color=col, alpha=0.10)
        ax_timing.plot(t_norm[mask], avg[mask], color=col, linewidth=1.8,
                       label=f'{td}ms delay')
 
    ax_timing.axvline(0, color=TEAL,   linewidth=1.1, linestyle='--', alpha=0.6)
    ax_timing.axvline(1, color=ORANGE, linewidth=1.1, linestyle='--', alpha=0.6)
    ax_timing.text(0.01, 0.95, 'CUE',    color=TEAL,   fontsize=7,
                   fontfamily='monospace', transform=ax_timing.transAxes)
    ax_timing.text(0.88, 0.95, 'REWARD', color=ORANGE, fontsize=7,
                   fontfamily='monospace', transform=ax_timing.transAxes)
 
    ax_timing.set_xlabel('Normalised time (cue=0, reward=1)',
                         color=TEXT, fontsize=8, fontfamily='monospace')
    ax_timing.set_ylabel('DA signal', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_timing.set_title('Ramp Shape Across Delay Durations',
                        color=WHITE, fontsize=9, fontfamily='monospace', pad=6)
    ax_timing.tick_params(colors=TEXT, labelsize=7)
    ax_timing.legend(fontsize=7, facecolor=BG, edgecolor=DIM, labelcolor=TEXT)
    # note: ramps converge to same endpoint regardless of delay
    ax_timing.text(0.35, 0.15,
                   'Ramp endpoint fixed at reward;\nslope adapts to interval length.',
                   color=GREY, fontsize=7, fontfamily='monospace',
                   transform=ax_timing.transAxes,
                   bbox=dict(boxstyle='round,pad=0.3', facecolor=BG,
                             edgecolor=DIM, linewidth=0.7))
 
 
def draw_heatmap(t_reward, n_trials=25):
    ax_heatmap.cla()
    ax_heatmap.set_facecolor(PANEL)
    for sp in ax_heatmap.spines.values(): sp.set_color(DIM); sp.set_linewidth(0.6)
 
    # trial-by-trial variability in the ramp
    # rows = trials, columns = time bins
    t_ref = np.arange(0, t_reward + 200, DT * 4)   # coarser for heatmap
    matrix = np.zeros((n_trials, len(t_ref)))
 
    rng = np.random.default_rng(seed=99)
    for trial in range(n_trials):
        # each trial: slightly different reward time (timing uncertainty)
        jitter  = rng.integers(-80, 80)
        td_jit  = max(t_reward + jitter, 400)
        _, sig  = make_ramp(td_jit, noise_level=0.04, neuron_idx=trial + 50)
        # interpolate to common time axis
        t_trial = np.arange(0, td_jit + 200, DT)
        interp  = np.interp(t_ref, t_trial, sig,
                            left=sig[0], right=sig[-1])
        matrix[trial] = interp
 
    from matplotlib.colors import LinearSegmentedColormap
    cmap = LinearSegmentedColormap.from_list(
        'ramp_heat', [BG, '#0d2137', BLUE, TEAL, GOLD, ORANGE], N=256
    )
    im = ax_heatmap.imshow(matrix, aspect='auto', cmap=cmap,
                           vmin=0, vmax=1.0, interpolation='bilinear',
                           extent=[t_ref[0], t_ref[-1], n_trials, 0])
 
    ax_heatmap.axvline(T_CUE, color=TEAL,   linewidth=1.2, linestyle='--', alpha=0.7)
    ax_heatmap.axvline(t_reward, color=ORANGE, linewidth=1.2, linestyle='--', alpha=0.7)
 
    ax_heatmap.set_xlabel('Time (ms)', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_heatmap.set_ylabel('Trial #', color=TEXT, fontsize=8, fontfamily='monospace')
    ax_heatmap.set_title('Trial-by-Trial Ramp Variability',
                         color=WHITE, fontsize=9, fontfamily='monospace', pad=6)
    ax_heatmap.tick_params(colors=TEXT, labelsize=7)
 
    cbar = plt.colorbar(im, ax=ax_heatmap, fraction=0.04, pad=0.02)
    cbar.ax.tick_params(colors=TEXT, labelsize=6)
    cbar.set_label('DA signal', color=TEXT, fontsize=7, fontfamily='monospace')
 
 
def draw_info(t_reward):
    ax_info.cla()
    ax_info.set_facecolor(PANEL)
    for sp in ax_info.spines.values(): sp.set_color(DIM); sp.set_linewidth(0.6)
    ax_info.axis('off')
    ax_info.set_title('What This Signal Means', color=WHITE, fontsize=9,
                      fontfamily='monospace', pad=6)
 
    notes = [
        (GOLD,   'THE RAMP ≠ PHASIC RPE',
                 f'RPE is a sharp burst at reward.\nThe ramp is a slow build during\nthe {t_reward}ms wait — different\nmechanism, different function.'),
        (TEAL,   'THREE COMPETING THEORIES',
                 'Time encoding (counting down),\nproximity to reward (distance),\nor integrated value estimate.\nStill debated as of 2024.'),
        (ORANGE, 'KEY PAPER — HOWE 2013',
                 'Measured with fast-scan cyclic\nvoltammetry in freely moving rats.\nFirst clean in-vivo demonstration\nof the ramp in NAc core.'),
    ]
 
    y = 0.94
    for col, title, body in notes:
        ax_info.text(0.04, y, f'▸ {title}', color=col, fontsize=7.5,
                     fontweight='bold', fontfamily='monospace',
                     transform=ax_info.transAxes, va='top')
        ax_info.text(0.04, y - 0.065, body, color=TEXT, fontsize=7.2,
                     fontfamily='monospace', transform=ax_info.transAxes,
                     va='top', linespacing=1.55)
        y -= 0.30
 
 
