# -------------------------------------------------------------------
# simulation parameters
# -------------------------------------------------------------------
# trial structure: cue at t=0, reward at t=T_reward
# I'm using 3 different reward delays to show how the ramp scales
T_CUE    = 0       # ms
T_DELAYS = [1000, 2000, 4000]   # short / medium / long delay
DT       = 5       # ms resolution
 
# number of simulated DA neurons (ventral striatum / NAc recordings)
N_NEURONS = 30
 
# -------------------------------------------------------------------
# signal generation
# -------------------------------------------------------------------
 
def make_ramp(t_reward, noise_level=0.04, neuron_idx=0):
    """
    Generates a single-trial dopamine ramp signal.
 
    The ramp rises roughly linearly from cue to reward,
    then drops at reward delivery (consumed by the RPE burst).
    Different neurons have slightly different slopes and onset latencies —
    that's the biological reality from Howe et al. 2013.
    """
    rng  = np.random.default_rng(seed=neuron_idx * 7 + t_reward)
    t    = np.arange(0, t_reward + 500, DT)
 
    # individual neuron variation: onset jitter + slope variability
    onset_delay = rng.integers(80, 250)      # ramp doesn't start instantly
    slope_scale = rng.uniform(0.55, 1.45)    # some neurons ramp steeper
 
    sig = np.zeros(len(t))
    ramp_start = np.searchsorted(t, onset_delay)
    ramp_end   = np.searchsorted(t, t_reward)
 
    if ramp_end > ramp_start:
        ramp_len = ramp_end - ramp_start
        # slightly nonlinear — accelerates near reward
        ramp_vals = np.linspace(0, 1, ramp_len) ** 0.85 * slope_scale
        sig[ramp_start:ramp_end] = ramp_vals
 
    # reward delivery: brief phasic burst then return to baseline
    burst_end = min(ramp_end + int(150 / DT), len(t))
    if burst_end > ramp_end:
        burst_t  = np.linspace(0, 1, burst_end - ramp_end)
        sig[ramp_end:burst_end] = slope_scale * np.exp(-burst_t * 4) * 0.6
 
    # baseline tonic + noise
    baseline = 0.12 + rng.uniform(-0.03, 0.03)
    sig      = sig + baseline + rng.normal(0, noise_level, len(sig))
 
    return t, np.clip(sig, 0, None)
 
 
def make_population_average(t_reward, n=N_NEURONS):
    """Average across n neurons — smooths out individual variability."""
    signals = []
    for i in range(n):
        t, s = make_ramp(t_reward, noise_level=0.025, neuron_idx=i)
        signals.append(s)
    arr = np.array(signals)
    return t, arr.mean(axis=0), arr.std(axis=0)
 
 
def make_raster(t_reward, n=N_NEURONS):
    """
    Convert the continuous ramp signal into spike times via
    inhomogeneous Poisson process — firing probability scales with signal.
    This is how the underlying physiology actually works.
    """
    all_spikes = []
    for i in range(n):
        t, sig = make_ramp(t_reward, noise_level=0.02, neuron_idx=i)
        rng    = np.random.default_rng(seed=i * 13 + t_reward)
        # scale signal to firing rate: baseline ~5Hz, peak ~30Hz
        rate   = sig * 28 + 4    # Hz
        prob   = rate * DT / 1000.0   # prob per bin
        spikes = t[rng.random(len(t)) < prob]
        all_spikes.append(spikes)
    return all_spikes
 
 
def make_timing_comparison():
    """
    The ramp slope adapts to the expected delay —
    steeper for short delays, shallower for long ones.
    Normalised to same endpoint so you can compare shapes.
    """
    results = {}
    for td in T_DELAYS:
        t, avg, std = make_population_average(td)
        # normalise time axis to 0–1
        t_norm = t / td
        results[td] = (t_norm, avg, std)
    return results
 
 
