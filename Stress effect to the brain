import numpy as np
import matplotlib.pyplot as plt
import matplotlib.colors as mcolors

# --- Data from stress neuroscience studies ---
regions = [
    'Amygdala', 'Prefrontal Cortex', 'Hippocampus',
    'Anterior Cingulate\nCortex (ACC)', 'Hypothalamus',
    'Nucleus Accumbens', 'Insula', 'Thalamus'
]

# Activation values: positive = increased, negative = suppressed
# Based on well-documented stress response findings
activation = [0.85, -0.70, -0.50, 0.60, 0.75, -0.30, 0.55, 0.40]

# --- Plot ---
fig, ax = plt.subplots(figsize=(10, 6))

# Color: red for activation, blue for suppression
cmap = plt.cm.RdBu_r
norm = mcolors.TwoSlopeNorm(vmin=-1, vcenter=0, vmax=1)
colors = [cmap(norm(v)) for v in activation]

bars = ax.barh(regions, activation, color=colors, edgecolor='black', linewidth=0.6)

# Reference line at 0
ax.axvline(0, color='black', linewidth=1.2)

# Labels
ax.set_xlabel('Activation Level (relative to baseline)', fontsize=12)
ax.set_title('Brain Region Activity Under Stress\n(based on fMRI/neuroscience literature)',
             fontsize=14, fontweight='bold')

# Colorbar legend
sm = plt.cm.ScalarMappable(cmap=cmap, norm=norm)
sm.set_array([])
cbar = plt.colorbar(sm, ax=ax, orientation='vertical', shrink=0.8)
cbar.set_label('Suppressed ← Baseline → Activated', fontsize=10)

# Value annotations on bars
for bar, val in zip(bars, activation):
    xpos = val + 0.02 if val >= 0 else val - 0.02
    ha = 'left' if val >= 0 else 'right'
    ax.text(xpos, bar.get_y() + bar.get_height() / 2,
            f'{val:+.2f}', va='center', ha=ha, fontsize=10)

ax.set_xlim(-1.1, 1.1)
plt.tight_layout()
plt.savefig('stress_brain_activity.png', dpi=150)
plt.show()
