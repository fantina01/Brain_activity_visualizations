GREEN     = '#2e7d32'
PURPLE    = '#6a1b9a'
 
# ── signal generation ─────────────────────────────────────────────────────────
FS        = 500      # sampling rate Hz
T_TOTAL   = 3.0      # seconds
T_STIM    = 1.0      # stimulus onset at 1s
N_TRIALS  = 40
N_CHANS   = 8        # simulated occipital channels
 
T_AXIS    = np.linspace(0, T_TOTAL, int(FS * T_TOTAL))
T_REL     = T_AXIS - T_STIM   # relative to stimulus
 
 
def make_alpha_signal(suppress=True, channel=0, trial=0):
    """
    Generate a realistic EEG-like signal with alpha rhythm.
    Pre-stimulus: strong alpha (8-12 Hz).
    Post-stimulus: alpha suppressed, broadband activity increases.
    """
    rng  = np.random.default_rng(seed=channel * 31 + trial * 7)
    t    = T_AXIS
    n    = len(t)
 
    # individual channel frequency variation (9-11 Hz)
    alpha_freq = 9.5 + rng.uniform(-0.8, 0.8) + channel * 0.15
 
    # amplitude variation across channels and trials
    pre_amp  = 8.0 + rng.uniform(-1.5, 1.5)
    post_amp = pre_amp * (0.25 + rng.uniform(-0.08, 0.08)) if suppress else pre_amp
 
    # build signal in segments
    sig = np.zeros(n)
    stim_idx = int(T_STIM * FS)
 
    # pre-stimulus: strong alpha
    t_pre = t[:stim_idx]
    phase_pre = rng.uniform(0, 2 * np.pi)
    sig[:stim_idx] = (
        pre_amp * np.sin(2 * np.pi * alpha_freq * t_pre + phase_pre) +
        rng.normal(0, 1.2, stim_idx)
    )
 
    # transition: brief 50-100ms of mixed activity
    trans_len = int(0.08 * FS)
    fade = np.linspace(1, 0, trans_len)
    sig[stim_idx:stim_idx + trans_len] = (
        pre_amp * fade * np.sin(2 * np.pi * alpha_freq * t[stim_idx:stim_idx + trans_len] + phase_pre) +
        rng.normal(0, 2.5, trans_len)
    )
 
    # post-stimulus: suppressed alpha + broadband evoked activity
    t_post = t[stim_idx + trans_len:]
    n_post = len(t_post)
    evoked_decay = np.exp(-t_post[:n_post] / 0.3) * 15 * np.sin(
        2 * np.pi * 3 * t_post[:n_post]
    ) * (1 if suppress else 0.3)
 
    sig[stim_idx + trans_len:] = (
        post_amp * np.sin(2 * np.pi * alpha_freq * t_post + rng.uniform(0, 2 * np.pi)) +
        evoked_decay +
        rng.normal(0, 2.0 if suppress else 1.2, n_post)
    )
 
    return sig
 
 
def compute_tfr(sig, fs=FS):
    """Time-frequency representation using short-time Fourier transform."""
    nperseg  = 128
    noverlap = 120
    f, t_spec, Sxx = scipy_signal.spectrogram(
        sig, fs=fs, nperseg=nperseg, noverlap=noverlap, scaling='density'
    )
    return f, t_spec, 10 * np.log10(Sxx + 1e-10)
 
 
def compute_ersp(n_trials=N_TRIALS, channel=0):
    """
    Event-related spectral perturbation — average power change
    across trials, relative to pre-stimulus baseline.
    This is the standard way to show alpha suppression in EEG papers.
    """
    nperseg  = 128
    noverlap = 120
    powers   = []
 
    for trial in range(n_trials):
        sig = make_alpha_signal(suppress=True, channel=channel, trial=trial)
        f, t_spec, Sxx_db = compute_tfr(sig)
        powers.append(Sxx_db)
 
    avg_power = np.mean(powers, axis=0)
 
    # baseline: pre-stimulus period
    stim_t   = T_STIM
    base_mask = t_spec < stim_t - 0.1
    baseline  = avg_power[:, base_mask].mean(axis=1, keepdims=True)
    ersp      = avg_power - baseline   # dB change from baseline
 
    return f, t_spec - T_STIM, ersp   # shift time to stimulus-relative
 
 
def compute_alpha_timecourse(n_trials=N_TRIALS, channel=0):
    """
    Band-pass filter at 8-12 Hz, extract instantaneous power via Hilbert,
    average across trials. Standard EEG analysis pipeline.
    """
    b, a = scipy_signal.butter(4, [8, 12], btype='bandpass', fs=FS)
    powers = []
 
    for trial in range(n_trials):
        sig       = make_alpha_signal(suppress=True, channel=channel, trial=trial)
        filtered  = scipy_signal.filtfilt(b, a, sig)
        analytic  = scipy_signal.hilbert(filtered)
        power     = np.abs(analytic) ** 2
        powers.append(power)
 
    avg = np.mean(powers, axis=0)
    sem = np.std(powers, axis=0) / np.sqrt(n_trials)
    return T_REL, avg, sem
 
 
def compute_topography(time_window='post'):
    """
    Simulated 2D scalp topography of alpha power.
    Pre-stimulus: posterior alpha dominant.
    Post-stimulus: posterior drops, frontal relatively preserved.
    """
    # 8x8 grid approximating scalp
    grid = np.zeros((8, 8))
    rng  = np.random.default_rng(seed=42)
 
    if time_window == 'pre':
        # strong occipital / parietal alpha
        for i in range(8):
            for j in range(8):
                dist_occ = np.sqrt((i - 6.5)**2 + (j - 3.5)**2)
                grid[i, j] = np.exp(-dist_occ / 2.5) * 8 + rng.uniform(0, 0.5)
    else:
        # post: occipital suppressed, frontal relatively preserved
        for i in range(8):
            for j in range(8):
                dist_occ   = np.sqrt((i - 6.5)**2 + (j - 3.5)**2)
                dist_front = np.sqrt((i - 0.5)**2 + (j - 3.5)**2)
                grid[i, j] = (
                    np.exp(-dist_occ / 2.5) * 1.5 +
                    np.exp(-dist_front / 2.0) * 3.0 +
                    rng.uniform(0, 0.3)
                )
    return grid
 
 
