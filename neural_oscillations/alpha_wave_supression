def style_ax(ax, title, xlabel='', ylabel=''):
    ax.set_title(title, color=TEXT, fontsize=9, fontfamily='monospace',
                 pad=7, fontweight='bold')
    ax.set_xlabel(xlabel, color=DIM, fontsize=8, fontfamily='monospace')
    ax.set_ylabel(ylabel, color=DIM, fontsize=8, fontfamily='monospace')
    ax.tick_params(colors=DIM, labelsize=7)
    ax.grid(True, color=GRID, linewidth=0.5, alpha=0.8)
    for sp in ax.spines.values():
        sp.set_edgecolor(BORDER); sp.set_linewidth(0.8)
 
 
# ── draw functions ────────────────────────────────────────────────────────────
 
def draw_raw():
    ax_raw.cla()
    style_ax(ax_raw, 'Raw EEG — Single Trial (Oz)',
             'Time (s)', 'Amplitude (μV)')
 
    sig = make_alpha_signal(suppress=True, channel=0, trial=3)
    ax_raw.plot(T_REL, sig, color=ALPHA_COL, linewidth=0.9, alpha=0.9)
    ax_raw.axvline(0, color=STIM_COL, linewidth=1.8, linestyle='--', zorder=5)
    ax_raw.text(0.02, ax_raw.get_ylim()[1] * 0.85 if ax_raw.get_ylim()[1] > 0 else 10,
                'Stimulus\nonset', color=STIM_COL, fontsize=7.5,
                fontfamily='monospace')
 
    # annotate pre and post regions
    ax_raw.axvspan(-1.0, 0, color=ALPHA_COL, alpha=0.06, label='Pre: strong alpha')
    ax_raw.axvspan(0, 2.0,  color=SUPPRESS,  alpha=0.05, label='Post: alpha suppressed')
    ax_raw.set_xlim(-1.0, 2.0)
    ax_raw.legend(fontsize=7, facecolor=BG, edgecolor=BORDER, loc='lower right')
 
 
def draw_tfr():
    ax_tfr.cla()
    sig   = make_alpha_signal(suppress=True, channel=0, trial=3)
    f, t_spec, Sxx = compute_tfr(sig)
    t_rel_spec = t_spec - T_STIM
 
    # focus on 2-30 Hz
    f_mask = (f >= 2) & (f <= 30)
 
    im = ax_tfr.imshow(
        Sxx[f_mask],
        aspect='auto', origin='lower',
        extent=[t_rel_spec[0], t_rel_spec[-1], f[f_mask][0], f[f_mask][-1]],
        cmap='RdBu_r', vmin=-15, vmax=15,
        interpolation='bilinear'
    )
    ax_tfr.axvline(0, color=STIM_COL, linewidth=1.5, linestyle='--')
    ax_tfr.axhline(8,  color='white', linewidth=0.6, linestyle=':', alpha=0.6)
    ax_tfr.axhline(12, color='white', linewidth=0.6, linestyle=':', alpha=0.6)
    ax_tfr.text(0.5, 9.8, 'Alpha band', color='white', fontsize=7,
                fontfamily='monospace', alpha=0.85)
 
    cbar = plt.colorbar(im, ax=ax_tfr, fraction=0.04, pad=0.02)
    cbar.set_label('Power (dB)', color=DIM, fontsize=7, fontfamily='monospace')
    cbar.ax.tick_params(colors=DIM, labelsize=6)
 
    style_ax(ax_tfr, 'Time-Frequency Representation',
             'Time rel. to stimulus (s)', 'Frequency (Hz)')
    ax_tfr.grid(False)
 
 
def draw_topo(time_window='post'):
    ax_topo.cla()
    ax_topo.set_facecolor(PANEL)
    for sp in ax_topo.spines.values():
        sp.set_edgecolor(BORDER); sp.set_linewidth(0.8)
 
    grid = compute_topography(time_window)
    im   = ax_topo.imshow(grid, cmap='Blues' if time_window == 'pre' else 'RdBu_r',
                          aspect='auto', interpolation='bicubic',
                          vmin=0 if time_window == 'pre' else -3)
 
    # electrode labels
    regions = {(0, 3): 'Fz', (3, 0): 'T7', (3, 7): 'T8',
               (3, 3): 'Cz', (6, 1): 'O1', (6, 5): 'O2', (6, 3): 'Oz'}
    for (r, c), label in regions.items():
        ax_topo.text(c, r, label, ha='center', va='center', fontsize=7,
                     color='white', fontfamily='monospace', fontweight='bold',
                     path_effects=[pe.withStroke(linewidth=1.5, foreground='black')])
 
    cbar = plt.colorbar(im, ax=ax_topo, fraction=0.046, pad=0.04)
    cbar.set_label('Alpha power', color=DIM, fontsize=7, fontfamily='monospace')
    cbar.ax.tick_params(colors=DIM, labelsize=6)
 
    label = 'Pre-stimulus' if time_window == 'pre' else 'Post-stimulus'
    ax_topo.set_title(f'Scalp Topography — {label}',
                      color=TEXT, fontsize=9, fontfamily='monospace',
                      pad=7, fontweight='bold')
    ax_topo.set_xticks([]); ax_topo.set_yticks([])
    ax_topo.text(0.02, 0.04, 'Frontal →\nOccipital', color=DIM, fontsize=6.5,
                 fontfamily='monospace', transform=ax_topo.transAxes, va='bottom')
 
 
def draw_timecourse():
    ax_tc.cla()
    style_ax(ax_tc, f'Alpha Power Timecourse  (n={N_TRIALS} trials)',
             'Time rel. to stimulus (s)', 'Alpha power (μV²)')
 
    t_rel, avg, sem = compute_alpha_timecourse(n_trials=N_TRIALS, channel=0)
 
    # smooth for display
    from scipy.ndimage import uniform_filter1d
    avg_s = uniform_filter1d(avg, size=30)
    sem_s = uniform_filter1d(sem, size=30)
 
    ax_tc.fill_between(t_rel, avg_s - sem_s, avg_s + sem_s,
                       color=ALPHA_COL, alpha=0.18, label='±SEM')
    ax_tc.plot(t_rel, avg_s, color=ALPHA_COL, linewidth=2.0, label='Mean alpha power')
 
    # baseline rectangle
    ax_tc.axvspan(-0.5, 0, color=ALPHA_COL, alpha=0.07, label='Baseline window')
    ax_tc.axvline(0, color=STIM_COL, linewidth=1.5, linestyle='--', label='Stimulus onset')
    ax_tc.axhline(avg_s[T_REL < -0.1].mean(), color=BASELINE,
                  linewidth=1.0, linestyle=':', alpha=0.7, label='Pre-stimulus mean')
 
    ax_tc.set_xlim(-1.0, 2.0)
    ax_tc.legend(fontsize=7, facecolor=BG, edgecolor=BORDER, ncol=2)
 
    # annotate suppression
    post_mean  = avg_s[(T_REL > 0.2) & (T_REL < 0.8)].mean()
    pre_mean   = avg_s[T_REL < -0.1].mean()
    pct_change = (post_mean - pre_mean) / pre_mean * 100
    ax_tc.text(0.55, 0.15, f'ERD: {pct_change:.0f}%',
               color=SUPPRESS, fontsize=9, fontweight='bold',
               fontfamily='monospace', transform=ax_tc.transAxes)
 
 
def draw_ersp():
    ax_ersp.cla()
    f, t_spec, ersp = compute_ersp(n_trials=N_TRIALS, channel=0)
    f_mask = (f >= 2) & (f <= 30)
 
    im = ax_ersp.imshow(
        ersp[f_mask],
        aspect='auto', origin='lower',
        extent=[t_spec[0], t_spec[-1], f[f_mask][0], f[f_mask][-1]],
        cmap='RdBu_r', vmin=-6, vmax=6,
        interpolation='bilinear'
    )
    ax_ersp.axvline(0, color=STIM_COL, linewidth=1.5, linestyle='--')
    ax_ersp.axhline(8,  color='white', linewidth=0.7, linestyle=':', alpha=0.5)
    ax_ersp.axhline(12, color='white', linewidth=0.7, linestyle=':', alpha=0.5)
 
    cbar = plt.colorbar(im, ax=ax_ersp, fraction=0.04, pad=0.02)
    cbar.set_label('ERSP (dB)', color=DIM, fontsize=7, fontfamily='monospace')
    cbar.ax.tick_params(colors=DIM, labelsize=6)
 
    style_ax(ax_ersp, f'ERSP — Trial Average  (n={N_TRIALS})',
             'Time rel. to stimulus (s)', 'Frequency (Hz)')
    ax_ersp.grid(False)
    ax_ersp.text(0.35, 9.5, 'Alpha\nsuppression', color='white', fontsize=7,
                 fontfamily='monospace', ha='center')
 
 
