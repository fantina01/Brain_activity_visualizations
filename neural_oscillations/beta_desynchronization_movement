# ── constants ─────────────────────────────────────────────────────────────────
FS         = 1000
T_TOTAL    = 4.0     # seconds
T_MOVEMENT = 1.5     # movement onset
T_END      = 2.2     # movement end
N_TRIALS   = 40
T_AXIS     = np.linspace(0, T_TOTAL, int(FS * T_TOTAL))
T_REL      = T_AXIS - T_MOVEMENT
 
 
def make_beta_signal(condition='healthy', trial=0):
    """
    Generate motor cortex EEG signal.
 
    healthy: clear ERD before movement, PMBR after
    parkinsons: elevated baseline beta, impaired ERD
    """
    rng   = np.random.default_rng(seed=trial * 19 + (0 if condition == 'healthy' else 200))
    t     = T_AXIS
    n     = len(t)
    sig   = np.zeros(n)
    f_beta = 20 + rng.uniform(-2, 2)
 
    move_idx = int(T_MOVEMENT * FS)
    end_idx  = int(T_END * FS)
 
    if condition == 'healthy':
        baseline_amp = 5.0 + rng.uniform(-0.5, 0.5)
        erd_depth    = 0.72 + rng.uniform(-0.08, 0.08)
        pmbr_amp     = 1.35 + rng.uniform(-0.10, 0.10)
    else:  # Parkinson's
        baseline_amp = 9.0 + rng.uniform(-0.8, 0.8)   # elevated
        erd_depth    = 0.30 + rng.uniform(-0.06, 0.06) # impaired suppression
        pmbr_amp     = 1.15 + rng.uniform(-0.08, 0.08)
 
    # pre-movement baseline beta
    sig[:move_idx] = baseline_amp * np.sin(
        2 * np.pi * f_beta * t[:move_idx] + rng.uniform(0, 2 * np.pi)
    )
 
    # ERD: gradual suppression starting 500ms before movement
    erd_start = max(0, move_idx - int(0.5 * FS))
    erd_len   = move_idx - erd_start + (end_idx - move_idx)
    t_erd     = t[erd_start:end_idx] - t[erd_start]
    fade_in   = np.clip(t_erd / 0.5, 0, 1)
    erd_env   = baseline_amp * (1 - erd_depth * fade_in)
    sig[erd_start:end_idx] = erd_env * np.sin(
        2 * np.pi * f_beta * t[erd_start:end_idx] + rng.uniform(0, 2 * np.pi)
    )
 
    # PMBR: rebound above baseline, 200-800ms after movement end
    pmbr_start = end_idx + int(0.15 * FS)
    pmbr_end   = min(n, end_idx + int(0.90 * FS))
    t_pmbr     = t[pmbr_start:pmbr_end] - t[pmbr_start]
    pmbr_env   = (baseline_amp * pmbr_amp *
                  np.exp(-t_pmbr / 0.4) * (1 - np.exp(-t_pmbr / 0.05)))
    sig[pmbr_start:pmbr_end] = pmbr_env * np.sin(
        2 * np.pi * f_beta * t[pmbr_start:pmbr_end] + rng.uniform(0, 2 * np.pi)
    )
 
    # return to baseline
    if pmbr_end < n:
        decay_len = n - pmbr_end
        t_decay   = t[pmbr_end:] - t[pmbr_end]
        env_return = baseline_amp * (1 - np.exp(-t_decay / 0.3))
        sig[pmbr_end:] = env_return * np.sin(
            2 * np.pi * f_beta * t[pmbr_end:] + rng.uniform(0, 2 * np.pi)
        )
 
    sig += rng.normal(0, 1.0, n)
    return sig
 
 
def compute_beta_timecourse(condition='healthy', n_trials=N_TRIALS):
    """Beta band power timecourse across trials."""
    b, a   = scipy_signal.butter(4, [13, 30], btype='bandpass', fs=FS)
    powers = []
    for trial in range(n_trials):
        sig     = make_beta_signal(condition=condition, trial=trial)
        filt    = scipy_signal.filtfilt(b, a, sig)
        power   = np.abs(scipy_signal.hilbert(filt)) ** 2
        powers.append(power)
    avg = np.mean(powers, axis=0)
    sem = np.std(powers, axis=0) / np.sqrt(n_trials)
    return T_REL, uniform_filter1d(avg, 40), uniform_filter1d(sem, 40)
 
 
def compute_tfr(condition='healthy', n_trials=8):
    """TFR across trials."""
    powers = []
    for trial in range(n_trials):
        sig = make_beta_signal(condition=condition, trial=trial)
        f, t_spec, Sxx = scipy_signal.spectrogram(
            sig, fs=FS, nperseg=256, noverlap=248, scaling='density'
        )
        powers.append(10 * np.log10(Sxx + 1e-10))
    avg    = np.mean(powers, axis=0)
    t_rel  = t_spec - T_MOVEMENT
    b_mask = (f >= 2) & (f <= 50)
    base   = avg[b_mask, t_spec < T_MOVEMENT - 0.2].mean(axis=1, keepdims=True)
    ersp   = avg[b_mask] - base
    return f[b_mask], t_rel, ersp
 
 
def compute_topography(phase='erd'):
    """Simulated 2D scalp topography of beta power."""
    grid = np.zeros((8, 8))
    rng  = np.random.default_rng(seed=99)
    for i in range(8):
        for j in range(8):
            dist_motor = np.sqrt((i - 3.0)**2 + (j - 3.5)**2)
            if phase == 'baseline':
                grid[i, j] = np.exp(-dist_motor / 2.0) * 7 + rng.uniform(0, 0.5)
            elif phase == 'erd':
                grid[i, j] = np.exp(-dist_motor / 2.0) * 1.5 + rng.uniform(0, 0.3)
            else:  # pmbr
                grid[i, j] = np.exp(-dist_motor / 1.8) * 9 + rng.uniform(0, 0.4)
    return grid
 
 
