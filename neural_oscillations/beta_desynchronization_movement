def draw_raw():
    ax_raw.cla()
    style_ax(ax_raw, 'Raw EEG — Motor Cortex (C3)',
             'Time rel. to movement (s)', 'Amplitude (μV)')
    sig = make_beta_signal(condition='healthy', trial=5)
    ax_raw.plot(T_REL, sig, color=BETA, linewidth=0.85, alpha=0.85)
    ax_raw.axvline(0,              color=MOVEMENT, linewidth=1.8, linestyle='--',
                   label='Movement onset', zorder=5)
    ax_raw.axvline(T_END - T_MOVEMENT, color=MOVEMENT, linewidth=1.2, linestyle=':',
                   alpha=0.7, label='Movement end', zorder=5)
    ax_raw.axvspan(-0.5, 0,            color=ERD, alpha=0.07, label='ERD window')
    ax_raw.axvspan(T_END - T_MOVEMENT,
                   T_END - T_MOVEMENT + 0.9, color=ERS, alpha=0.07, label='PMBR window')
    ax_raw.set_xlim(-1.5, 2.5)
    ax_raw.legend(fontsize=7, facecolor=BG, edgecolor=BORDER, ncol=2)
 
 
def draw_tfr():
    ax_tfr.cla()
    f, t_rel, ersp = compute_tfr(condition='healthy')
    im = ax_tfr.imshow(
        ersp, aspect='auto', origin='lower',
        extent=[t_rel[0], t_rel[-1], f[0], f[-1]],
        cmap='RdBu_r', vmin=-8, vmax=8, interpolation='bilinear'
    )
    ax_tfr.axvline(0, color=MOVEMENT, linewidth=1.5, linestyle='--')
    ax_tfr.axvline(T_END - T_MOVEMENT, color=MOVEMENT, linewidth=1.0,
                   linestyle=':', alpha=0.7)
    ax_tfr.axhline(13, color='white', linewidth=0.6, linestyle=':', alpha=0.5)
    ax_tfr.axhline(30, color='white', linewidth=0.6, linestyle=':', alpha=0.5)
    ax_tfr.text(-1.0, 20, 'Beta', color='white', fontsize=7.5, fontfamily='monospace')
    cbar = plt.colorbar(im, ax=ax_tfr, fraction=0.04, pad=0.02)
    cbar.set_label('ERSP (dB)', color=DIM, fontsize=7, fontfamily='monospace')
    cbar.ax.tick_params(colors=DIM, labelsize=6)
    style_ax(ax_tfr, 'ERSP — Motor Cortex',
             'Time rel. to movement (s)', 'Frequency (Hz)')
    ax_tfr.grid(False)
 
 
def draw_topo(phase='erd'):
    ax_topo.cla()
    ax_topo.set_facecolor(PANEL)
    for sp in ax_topo.spines.values():
        sp.set_edgecolor(BORDER); sp.set_linewidth(0.8)
    grid   = compute_topography(phase)
    cmaps  = dict(baseline='Blues', erd='RdBu_r', pmbr='Greens')
    labels = dict(baseline='Baseline Beta', erd='ERD (suppression)',
                  pmbr='Post-Movement Rebound')
    im = ax_topo.imshow(grid, cmap=cmaps[phase], aspect='auto',
                        interpolation='bicubic')
    electrodes = {(1, 3): 'Fz', (3, 0): 'C3', (3, 3): 'Cz',
                  (3, 6): 'C4', (5, 3): 'Pz'}
    for (r, c), label in electrodes.items():
        ax_topo.text(c, r, label, ha='center', va='center', fontsize=7.5,
                     color='white', fontfamily='monospace', fontweight='bold',
                     path_effects=[pe.withStroke(linewidth=2, foreground='black')])
    cbar = plt.colorbar(im, ax=ax_topo, fraction=0.046, pad=0.04)
    cbar.ax.tick_params(colors=DIM, labelsize=6)
    ax_topo.set_title(f'Topography — {labels[phase]}', color=TEXT, fontsize=9,
                      fontfamily='monospace', pad=7, fontweight='bold')
    ax_topo.set_xticks([]); ax_topo.set_yticks([])
    ax_topo.text(0.02, 0.04, 'Frontal →\nParietal', color=DIM, fontsize=6,
                 fontfamily='monospace', transform=ax_topo.transAxes)
 
 
def draw_timecourse():
    ax_tc.cla()
    style_ax(ax_tc, f'Beta Power Timecourse  (n={N_TRIALS} trials)',
             'Time rel. to movement (s)', 'Beta power (μV²)')
    t_rel, avg, sem = compute_beta_timecourse('healthy')
    ax_tc.fill_between(t_rel, avg - sem, avg + sem, color=HEALTHY, alpha=0.15)
    ax_tc.plot(t_rel, avg, color=HEALTHY, linewidth=2.0, label='Healthy')
 
    base = avg[T_REL < -0.8].mean()
    ax_tc.axhline(base, color=DIM, linewidth=0.8, linestyle=':', alpha=0.6)
    ax_tc.axvline(0, color=MOVEMENT, linewidth=1.5, linestyle='--', label='Movement')
    ax_tc.axvline(T_END - T_MOVEMENT, color=MOVEMENT, linewidth=1.0,
                  linestyle=':', alpha=0.7)
 
    # annotate ERD and PMBR
    ax_tc.annotate('ERD', xy=(-0.2, avg[(T_REL > -0.3) & (T_REL < 0)].mean()),
                   xytext=(-0.8, avg[(T_REL > -0.3) & (T_REL < 0)].mean() * 0.6),
                   color=ERD, fontsize=8, fontfamily='monospace', fontweight='bold',
                   arrowprops=dict(arrowstyle='->', color=ERD, lw=1.2))
    ax_tc.annotate('PMBR', xy=(1.0, avg[(T_REL > 0.8) & (T_REL < 1.2)].mean()),
                   xytext=(1.4, avg[(T_REL > 0.8) & (T_REL < 1.2)].mean() * 1.3),
                   color=ERS, fontsize=8, fontfamily='monospace', fontweight='bold',
                   arrowprops=dict(arrowstyle='->', color=ERS, lw=1.2))
 
    ax_tc.set_xlim(-1.5, 2.5)
    ax_tc.legend(fontsize=7, facecolor=BG, edgecolor=BORDER)
 
 
def draw_pd_comparison():
    ax_pd.cla()
    style_ax(ax_pd, "Healthy vs Parkinson's Disease",
             'Time rel. to movement (s)', 'Beta power (μV²)')
    for cond, col, lbl in [
        ('healthy',    HEALTHY, 'Healthy'),
        ('parkinsons', PD_COL,  "Parkinson's"),
    ]:
        t_rel, avg, sem = compute_beta_timecourse(cond, n_trials=30)
        ax_pd.fill_between(t_rel, avg - sem, avg + sem, color=col, alpha=0.12)
        ax_pd.plot(t_rel, avg, color=col, linewidth=2.0, label=lbl)
 
    ax_pd.axvline(0, color=MOVEMENT, linewidth=1.4, linestyle='--')
    ax_pd.set_xlim(-1.5, 2.5)
    ax_pd.legend(fontsize=8, facecolor=BG, edgecolor=BORDER)
    ax_pd.text(0.04, 0.88,
               "Elevated baseline beta in PD\ncorrelates with rigidity\nand motor freezing",
               color=PD_COL, fontsize=7.5, fontfamily='monospace',
               transform=ax_pd.transAxes, va='top',
               bbox=dict(boxstyle='round,pad=0.4', facecolor='#f3e5f5',
                         edgecolor=PD_COL, linewidth=0.8))
 
 
