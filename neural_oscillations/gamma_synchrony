"""
gamma_synchrony_consciousness.py
----------------------------------
Gamma oscillations (30-100 Hz, typically 40 Hz) are the fastest
rhythms routinely measured in EEG. They appear when neurons fire
together in tight temporal windows — synchrony that is thought to
"bind" distributed features of a percept into a unified conscious
experience.
 
The key finding: the same stimulus, processed the same way in
early visual cortex, produces gamma synchrony in higher areas
ONLY when it reaches consciousness. When it doesn't (masked,
inattentional blindness, binocular suppression), gamma stays local
and weak. This is the gamma-consciousness link.
 
Crick & Koch (1990) first proposed gamma as the neural correlate
of consciousness. It remains debated but it is the most specific
oscillatory signature we have.
 
What this visualization shows:
1. Raw gamma signal: conscious vs unconscious condition
2. Time-frequency: how gamma power differs between conditions
3. Inter-site phase synchrony: long-range coupling (the key signal)
4. Power spectrum comparison
5. Trial-by-trial variability
6. The perceptual threshold curve
 
References:
  - Crick & Koch (1990) Semin Neurosci 2:263
  - Rodriguez et al. (1999) Nature 397:430  — face perception gamma
  - Fries (2005) Trends Cogn Sci 9:474      — communication through coherence
  - Melloni et al. (2007) J Neurosci 27:2858 — gamma and consciousness
  - Dehaene & Changeux (2011) Neuron 70:200  — global workspace
 
pip install matplotlib numpy scipy
"""
 
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.gridspec as gridspec
from scipy import signal as scipy_signal
from scipy.ndimage import uniform_filter1d
import matplotlib.patheffects as pe
from matplotlib.widgets import Button
 
np.random.seed(14)
 
# ── palette ───────────────────────────────────────────────────────────────────
BG       = '#ffffff'
PANEL    = '#f8f9fa'
BORDER   = '#dee2e6'
CONSCIOUS   = '#d32f2f'   # red  — conscious condition
UNCONSCIOUS = '#1565c0'   # blue — unconscious condition
STIM_COL = '#e65100'
TEXT     = '#1a1a2e'
DIM      = '#6c757d'
GRID     = '#e9ecef'
GAMMA_C  = '#b71c1c'
GAMMA_U  = '#0d47a1'
GREEN    = '#1b5e20'
 
# ── constants ─────────────────────────────────────────────────────────────────
FS        = 1000
T_TOTAL   = 2.0
T_STIM    = 0.5
N_TRIALS  = 50
T_AXIS    = np.linspace(0, T_TOTAL, int(FS * T_TOTAL))
T_REL     = T_AXIS - T_STIM
 
 
def make_gamma_signal(conscious=True, trial=0, site='occipital'):
    """
    Generate EEG signal with gamma component.
 
    Conscious: strong 40Hz synchrony, sustained 200-600ms post-stimulus,
               spreads to frontal (long-range coupling)
    Unconscious: brief, weak, local gamma only; no frontal spread
    """
    rng = np.random.default_rng(seed=trial * 17 + (0 if conscious else 100) +
                                 (0 if site == 'occipital' else 50))
    t   = T_AXIS
    n   = len(t)
    sig = rng.normal(0, 2.5, n)   # background EEG noise
 
    stim_idx = int(T_STIM * FS)
 
    # evoked response (both conditions)
    t_post  = t[stim_idx:] - T_STIM
    n_post  = len(t_post)
    evoked  = 6 * np.exp(-t_post / 0.15) * np.sin(2 * np.pi * 10 * t_post)
    sig[stim_idx:] += evoked
 
    if conscious:
        # sustained 40Hz burst, 80-600ms
        gamma_start = stim_idx + int(0.08 * FS)
        gamma_end   = stim_idx + int(0.60 * FS)
        gamma_len   = gamma_end - gamma_start
        t_gamma     = t[gamma_start:gamma_end] - T_STIM - 0.08
        amplitude   = 4.5 * (1 - np.exp(-t_gamma / 0.05)) * np.exp(-t_gamma / 0.35)
        if site == 'frontal':
            # frontal gamma is delayed ~30ms and slightly weaker (long-range)
            amplitude *= 0.65
            amplitude = np.roll(amplitude, int(0.03 * FS))
        phase = rng.uniform(0, 2 * np.pi)
        sig[gamma_start:gamma_end] += amplitude * np.sin(
            2 * np.pi * 40 * t_gamma + phase
        )
    else:
        # brief, weak gamma burst only, 80-200ms
        gamma_start = stim_idx + int(0.08 * FS)
        gamma_end   = stim_idx + int(0.20 * FS)
        gamma_len   = gamma_end - gamma_start
        t_gamma     = t[gamma_start:gamma_end] - T_STIM - 0.08
        amplitude   = 1.2 * np.exp(-t_gamma / 0.04)
        if site == 'frontal':
            amplitude *= 0.15   # almost no frontal spread
        phase = rng.uniform(0, 2 * np.pi)
        sig[gamma_start:gamma_end] += amplitude * np.sin(
            2 * np.pi * 40 * t_gamma + phase
        )
 
    return sig
 
 
def compute_power_spectrum(conscious=True, n_trials=N_TRIALS):
    """Average power spectrum across trials."""
    spectra = []
    for trial in range(n_trials):
        sig = make_gamma_signal(conscious=conscious, trial=trial)
        f, Pxx = scipy_signal.welch(sig, fs=FS, nperseg=512)
        spectra.append(Pxx)
    return f, np.mean(spectra, axis=0), np.std(spectra, axis=0) / np.sqrt(n_trials)
 
 
def compute_gamma_timecourse(conscious=True, n_trials=N_TRIALS, site='occipital'):
    """Band-pass 30-70 Hz, Hilbert envelope, average across trials."""
    b, a   = scipy_signal.butter(4, [30, 70], btype='bandpass', fs=FS)
    powers = []
    for trial in range(n_trials):
        sig      = make_gamma_signal(conscious=conscious, trial=trial, site=site)
        filtered = scipy_signal.filtfilt(b, a, sig)
        power    = np.abs(scipy_signal.hilbert(filtered)) ** 2
        powers.append(power)
    avg = np.mean(powers, axis=0)
    sem = np.std(powers, axis=0) / np.sqrt(n_trials)
    return T_REL, uniform_filter1d(avg, 40), uniform_filter1d(sem, 40)
 
 
def compute_isps(n_trials=N_TRIALS):
    """
    Inter-Site Phase Synchrony between occipital and frontal.
    ISPS measures how consistently two sites synchronize in phase —
    the key measure of long-range gamma coupling.
    Computed as |mean(e^{i*phase_diff})| across trials.
    """
    b, a   = scipy_signal.butter(4, [30, 70], btype='bandpass', fs=FS)
    phase_diffs_c = []
    phase_diffs_u = []
 
    for trial in range(n_trials):
        for conscious, collector in [(True, phase_diffs_c), (False, phase_diffs_u)]:
            sig_occ   = make_gamma_signal(conscious=conscious, trial=trial, site='occipital')
            sig_front = make_gamma_signal(conscious=conscious, trial=trial, site='frontal')
            ph_occ    = np.angle(scipy_signal.hilbert(scipy_signal.filtfilt(b, a, sig_occ)))
            ph_front  = np.angle(scipy_signal.hilbert(scipy_signal.filtfilt(b, a, sig_front)))
            collector.append(np.exp(1j * (ph_occ - ph_front)))
 
    isps_c = np.abs(np.mean(phase_diffs_c, axis=0))
    isps_u = np.abs(np.mean(phase_diffs_u, axis=0))
    isps_c = uniform_filter1d(isps_c, 50)
    isps_u = uniform_filter1d(isps_u, 50)
    return T_REL, isps_c, isps_u
 
 
def compute_tfr_gamma(conscious=True, n_trials=10):
    """TFR focused on gamma band, averaged across trials."""
    powers = []
    for trial in range(n_trials):
        sig = make_gamma_signal(conscious=conscious, trial=trial)
        f, t_spec, Sxx = scipy_signal.spectrogram(
            sig, fs=FS, nperseg=128, noverlap=120, scaling='density'
        )
        powers.append(10 * np.log10(Sxx + 1e-10))
    return f, t_spec - T_STIM, np.mean(powers, axis=0)
 
 
