ax_hdr = fig.add_subplot(outer[0])
ax_hdr.set_facecolor(BG); ax_hdr.axis('off')
ax_hdr.text(0.0, 0.82, 'Gamma Synchrony  (30–70 Hz)  —  Conscious vs Unconscious',
            color=TEXT, fontsize=16, fontweight='bold',
            fontfamily='monospace', transform=ax_hdr.transAxes)
ax_hdr.text(0.0, 0.18,
            'Long-Range Phase Coupling · Neural Binding · '
            'Rodriguez et al. (1999)  ·  Melloni et al. (2007)  ·  Fries (2005)',
            color=DIM, fontsize=9, fontfamily='monospace',
            transform=ax_hdr.transAxes)
 
inner = gridspec.GridSpecFromSubplotSpec(
    2, 3, subplot_spec=outer[1],
    hspace=0.55, wspace=0.38,
    height_ratios=[1, 1]
)
 
ax_raw    = fig.add_subplot(inner[0, 0])
ax_tfr    = fig.add_subplot(inner[0, 1])
ax_isps   = fig.add_subplot(inner[0, 2])
ax_tc     = fig.add_subplot(inner[1, 0])
ax_psd    = fig.add_subplot(inner[1, 1])
ax_info   = fig.add_subplot(inner[1, 2])
 
for ax in [ax_raw, ax_tfr, ax_isps, ax_tc, ax_psd, ax_info]:
    ax.set_facecolor(PANEL)
    for sp in ax.spines.values():
        sp.set_edgecolor(BORDER); sp.set_linewidth(0.8)
 
 
def style_ax(ax, title, xlabel='', ylabel=''):
    ax.set_title(title, color=TEXT, fontsize=9, fontfamily='monospace',
                 pad=7, fontweight='bold')
    ax.set_xlabel(xlabel, color=DIM, fontsize=8, fontfamily='monospace')
    ax.set_ylabel(ylabel, color=DIM, fontsize=8, fontfamily='monospace')
    ax.tick_params(colors=DIM, labelsize=7)
    ax.grid(True, color=GRID, linewidth=0.5, alpha=0.8)
    for sp in ax.spines.values():
        sp.set_edgecolor(BORDER); sp.set_linewidth(0.8)
 
 
def draw_raw():
    ax_raw.cla()
    style_ax(ax_raw, 'Raw EEG — Conscious vs Unconscious',
             'Time rel. to stimulus (s)', 'Amplitude (μV)')
    sig_c = make_gamma_signal(conscious=True,  trial=2)
    sig_u = make_gamma_signal(conscious=False, trial=2)
    ax_raw.plot(T_REL, sig_c + 20, color=CONSCIOUS,   linewidth=0.85,
                alpha=0.9, label='Conscious (+offset)')
    ax_raw.plot(T_REL, sig_u - 20, color=UNCONSCIOUS, linewidth=0.85,
                alpha=0.9, label='Unconscious (−offset)')
    ax_raw.axvline(0, color=STIM_COL, linewidth=1.6, linestyle='--', zorder=5)
    ax_raw.text(0.02, 25, 'Sustained 40Hz\ngamma burst', color=CONSCIOUS,
                fontsize=7, fontfamily='monospace')
    ax_raw.text(0.02, -28, 'Brief, weak\ngamma only', color=UNCONSCIOUS,
                fontsize=7, fontfamily='monospace')
    ax_raw.set_xlim(-0.3, 1.5)
    ax_raw.legend(fontsize=7, facecolor=BG, edgecolor=BORDER, loc='upper right')
 
 
def draw_tfr():
    ax_tfr.cla()
    f_c, t_c, tfr_c = compute_tfr_gamma(conscious=True,  n_trials=8)
    f_u, t_u, tfr_u = compute_tfr_gamma(conscious=False, n_trials=8)
    diff = tfr_c - tfr_u
    f_mask = (f_c >= 5) & (f_c <= 80)
 
    im = ax_tfr.imshow(
        diff[f_mask],
        aspect='auto', origin='lower',
        extent=[t_c[0], t_c[-1], f_c[f_mask][0], f_c[f_mask][-1]],
        cmap='RdBu_r', vmin=-8, vmax=8,
        interpolation='bilinear'
    )
    ax_tfr.axvline(0, color=STIM_COL, linewidth=1.4, linestyle='--')
    ax_tfr.axhline(30, color='white', linewidth=0.6, linestyle=':', alpha=0.6)
    ax_tfr.axhline(70, color='white', linewidth=0.6, linestyle=':', alpha=0.6)
    ax_tfr.text(0.3, 45, 'Gamma\n(conscious\n> uncons.)', color='white',
                fontsize=7, fontfamily='monospace', ha='center')
 
    cbar = plt.colorbar(im, ax=ax_tfr, fraction=0.04, pad=0.02)
    cbar.set_label('Δ Power (dB)', color=DIM, fontsize=7, fontfamily='monospace')
    cbar.ax.tick_params(colors=DIM, labelsize=6)
    style_ax(ax_tfr, 'TFR Difference  (Conscious − Unconscious)',
             'Time rel. to stimulus (s)', 'Frequency (Hz)')
    ax_tfr.grid(False)
 
 
def draw_isps():
    ax_isps.cla()
    style_ax(ax_isps, 'Inter-Site Phase Synchrony  (Occipital–Frontal)',
             'Time rel. to stimulus (s)', 'ISPS  (0=random, 1=locked)')
    t_rel, isps_c, isps_u = compute_isps(n_trials=N_TRIALS)
    ax_isps.fill_between(t_rel, isps_u, isps_c,
                         color=CONSCIOUS, alpha=0.15, label='Difference')
    ax_isps.plot(t_rel, isps_c, color=CONSCIOUS,   linewidth=2.0, label='Conscious')
    ax_isps.plot(t_rel, isps_u, color=UNCONSCIOUS, linewidth=2.0, label='Unconscious')
    ax_isps.axvline(0, color=STIM_COL, linewidth=1.4, linestyle='--')
    ax_isps.axhline(0.1, color=DIM, linewidth=0.8, linestyle=':', alpha=0.5,
                    label='Chance level')
    ax_isps.set_xlim(-0.3, 1.5)
    ax_isps.set_ylim(0, 0.5)
    ax_isps.legend(fontsize=7, facecolor=BG, edgecolor=BORDER)
    ax_isps.text(0.30, 0.78,
                 'Long-range synchrony\nonly in conscious trials',
                 color=CONSCIOUS, fontsize=7.5, fontfamily='monospace',
                 transform=ax_isps.transAxes)
 
 
def draw_timecourse():
    ax_tc.cla()
    style_ax(ax_tc, f'Gamma Power Timecourse  (n={N_TRIALS} trials)',
             'Time rel. to stimulus (s)', 'Gamma power (μV²)')
    for conscious, col, label in [
        (True,  CONSCIOUS,   'Conscious — occipital'),
        (False, UNCONSCIOUS, 'Unconscious — occipital'),
        (True,  '#ff8a80',   'Conscious — frontal'),
    ]:
        site = 'frontal' if 'frontal' in label else 'occipital'
        t_rel, avg, sem = compute_gamma_timecourse(
            conscious=conscious, n_trials=N_TRIALS, site=site
        )
        lw = 2.0 if site == 'occipital' else 1.3
        ls = '-' if site == 'occipital' else '--'
        ax_tc.fill_between(t_rel, avg - sem, avg + sem, color=col, alpha=0.12)
        ax_tc.plot(t_rel, avg, color=col, linewidth=lw, linestyle=ls, label=label)
 
    ax_tc.axvline(0, color=STIM_COL, linewidth=1.4, linestyle='--')
    ax_tc.set_xlim(-0.3, 1.5)
    ax_tc.legend(fontsize=7, facecolor=BG, edgecolor=BORDER)
 
 
def draw_psd():
    ax_psd.cla()
    style_ax(ax_psd, 'Power Spectral Density  (post-stimulus)',
             'Frequency (Hz)', 'Power (μV²/Hz, log)')
    f_c, psd_c, sem_c = compute_power_spectrum(conscious=True,  n_trials=N_TRIALS)
    f_u, psd_u, sem_u = compute_power_spectrum(conscious=False, n_trials=N_TRIALS)
 
    mask = (f_c >= 1) & (f_c <= 100)
    ax_psd.fill_between(f_c[mask], psd_c[mask] - sem_c[mask],
                        psd_c[mask] + sem_c[mask], color=CONSCIOUS, alpha=0.12)
    ax_psd.fill_between(f_u[mask], psd_u[mask] - sem_u[mask],
                        psd_u[mask] + sem_u[mask], color=UNCONSCIOUS, alpha=0.12)
    ax_psd.semilogy(f_c[mask], psd_c[mask], color=CONSCIOUS,
                    linewidth=2.0, label='Conscious')
    ax_psd.semilogy(f_u[mask], psd_u[mask], color=UNCONSCIOUS,
                    linewidth=2.0, label='Unconscious')
    ax_psd.axvspan(30, 70, color=GAMMA_C, alpha=0.07, label='Gamma band')
    ax_psd.legend(fontsize=7, facecolor=BG, edgecolor=BORDER)
 
 
