def style_ax(ax, title, xlabel='', ylabel=''):
    ax.set_title(title, color=TEXT, fontsize=9, fontfamily='monospace',
                 pad=7, fontweight='bold')
    ax.set_xlabel(xlabel, color=DIM, fontsize=8, fontfamily='monospace')
    ax.set_ylabel(ylabel, color=DIM, fontsize=8, fontfamily='monospace')
    ax.tick_params(colors=DIM, labelsize=7)
    ax.grid(True, color=GRID, linewidth=0.5, alpha=0.8)
    for sp in ax.spines.values():
        sp.set_edgecolor(BORDER); sp.set_linewidth(0.8)
 
 
def draw_raw(n_items=4):
    ax_raw.cla()
    style_ax(ax_raw, f'Theta–Gamma Signal  ({n_items} items)',
             'Time (s)', 'Amplitude (μV)')
 
    sig, theta, gamma_comp = make_theta_gamma_signal(n_items=n_items)
 
    # show first 600ms for clarity
    mask = T_AXIS < 0.6
    t_show = T_AXIS[mask]
 
    ax_raw.plot(t_show, sig[mask],    color=COUPLED, linewidth=1.0,
                alpha=0.85, label='Coupled signal', zorder=3)
    ax_raw.plot(t_show, theta[mask] * 3.5, color=THETA, linewidth=1.5,
                alpha=0.6, linestyle='--', label='Theta (×3.5)', zorder=2)
 
    # highlight individual gamma bursts
    theta_period = 1.0 / THETA_FREQ
    for cycle in range(3):
        for item in range(n_items):
            burst_t   = cycle * theta_period + item / n_items * theta_period
            if burst_t < 0.6:
                ax_raw.axvspan(burst_t, burst_t + 0.02,
                               color=ITEM_COLORS[item % len(ITEM_COLORS)],
                               alpha=0.25, zorder=1)
                if cycle == 0:
                    ax_raw.text(burst_t + 0.005, 8,
                                f'#{item+1}', color=ITEM_COLORS[item % len(ITEM_COLORS)],
                                fontsize=6.5, fontfamily='monospace', fontweight='bold')
 
    ax_raw.set_xlim(0, 0.6)
    ax_raw.legend(fontsize=7, facecolor=BG, edgecolor=BORDER)
    ax_raw.text(0.60, 0.88, f'7±2 items\nmax capacity',
                color=DIM, fontsize=7, fontfamily='monospace',
                transform=ax_raw.transAxes, ha='right', va='top')
 
 
def draw_pac(n_items=4):
    ax_pac.cla()
    sig, _, _ = make_theta_gamma_signal(n_items=n_items)
    phase_freqs, amp_freqs, pac = compute_pac_comodulogram(sig)
 
    im = ax_pac.imshow(
        pac, aspect='auto', origin='lower',
        extent=[phase_freqs[0], phase_freqs[-1], amp_freqs[0], amp_freqs[-1]],
        cmap='hot', interpolation='bicubic'
    )
    ax_pac.axvline(THETA_FREQ, color='cyan', linewidth=1.2, linestyle='--', alpha=0.8)
    ax_pac.axhline(GAMMA_FREQ, color='cyan', linewidth=1.2, linestyle='--', alpha=0.8)
    ax_pac.text(THETA_FREQ + 0.3, GAMMA_FREQ + 3, f'θ={THETA_FREQ}Hz\nγ={int(GAMMA_FREQ)}Hz',
                color='cyan', fontsize=7, fontfamily='monospace')
 
    cbar = plt.colorbar(im, ax=ax_pac, fraction=0.04, pad=0.02)
    cbar.set_label('MVL (coupling)', color=DIM, fontsize=7, fontfamily='monospace')
    cbar.ax.tick_params(colors=DIM, labelsize=6)
    style_ax(ax_pac, 'PAC Comodulogram',
             'Phase frequency (Hz)', 'Amplitude frequency (Hz)')
    ax_pac.grid(False)
 
 
def draw_phase(n_items=4):
    ax_phase.cla()
    style_ax(ax_phase, 'Gamma Amplitude by Theta Phase',
             'Theta phase (rad)', 'Mean gamma amplitude')
 
    sig, _, _ = make_theta_gamma_signal(n_items=n_items)
    bins, amp = compute_phase_amplitude_relationship(sig)
 
    # repeat for wrapping
    bins_ext = np.concatenate([bins, bins + 2 * np.pi])
    amp_ext  = np.concatenate([amp, amp])
 
    ax_phase.fill_between(bins, amp, alpha=0.20, color=GAMMA)
    ax_phase.plot(bins, amp, color=GAMMA, linewidth=2.0)
 
    # mark theta peaks/troughs
    ax_phase.axvline(0,           color=THETA, linewidth=1.2, linestyle='--',
                     alpha=0.6, label='Theta peak (0)')
    ax_phase.axvline(-np.pi / 2, color=THETA, linewidth=0.8, linestyle=':',
                     alpha=0.5, label='Trough (−π/2)')
    ax_phase.set_xticks([-np.pi, -np.pi/2, 0, np.pi/2, np.pi])
    ax_phase.set_xticklabels(['-π', '-π/2', '0', 'π/2', 'π'],
                              fontfamily='monospace', fontsize=7)
    ax_phase.legend(fontsize=7, facecolor=BG, edgecolor=BORDER)
    ax_phase.text(0.55, 0.88,
                  'Each peak = one\nmemory item slot',
                  color=GAMMA, fontsize=7.5, fontfamily='monospace',
                  transform=ax_phase.transAxes)
 
 
def draw_model(n_items=4):
    ax_model.cla()
    ax_model.set_facecolor(PANEL)
    for sp in ax_model.spines.values():
        sp.set_edgecolor(BORDER); sp.set_linewidth(0.8)
    ax_model.axis('off')
    ax_model.set_xlim(0, 1); ax_model.set_ylim(0, 1)
    ax_model.set_title(f'Temporal Multiplexing Model  ({n_items} items)',
                       color=TEXT, fontsize=9, fontfamily='monospace',
                       pad=7, fontweight='bold')
 
    # draw theta cycle
    t_cycle = np.linspace(0, 1, 200)
    theta_y = 0.55 + 0.12 * np.sin(2 * np.pi * t_cycle)
    ax_model.plot(t_cycle, theta_y, color=THETA, linewidth=2.5, alpha=0.7)
 
    # draw gamma bursts at specific phases
    for item in range(n_items):
        phase_frac = item / n_items
        x_pos      = phase_frac + 0.5 / n_items
        if x_pos > 1: x_pos -= 1
        col        = ITEM_COLORS[item % len(ITEM_COLORS)]
 
        # gamma burst
        t_burst = np.linspace(x_pos - 0.04, x_pos + 0.04, 40)
        gamma_y = 0.55 + 0.08 * np.sin(2 * np.pi * 5 * (t_burst - x_pos + 0.04) / 0.08)
        mask    = (t_burst >= 0) & (t_burst <= 1)
        ax_model.plot(t_burst[mask], gamma_y[mask], color=col, linewidth=2.0)
 
        # item label
        ax_model.text(x_pos, 0.30, f'Item {item+1}',
                      color=col, fontsize=7.5, fontweight='bold',
                      fontfamily='monospace', ha='center', va='center')
        ax_model.plot([x_pos, x_pos], [0.34, 0.50], color=col,
                      linewidth=0.8, linestyle='--', alpha=0.5)
 
    ax_model.text(0.5, 0.88, '← one theta cycle (≈166ms) →',
                  color=THETA, fontsize=7.5, fontfamily='monospace',
                  ha='center', transform=ax_model.transAxes)
    ax_model.text(0.5, 0.12,
                  'Each item = distinct gamma sub-window\nwithin the same theta cycle',
                  color=DIM, fontsize=7, fontfamily='monospace',
                  ha='center', transform=ax_model.transAxes)
 
 
def draw_load():
    ax_load.cla()
    style_ax(ax_load, 'Coupling Strength vs Memory Load',
             'Number of items in memory', 'PAC strength (MVL)')
 
    loads   = np.arange(1, 9)
    pac_str = []
    for n in loads:
        sig, _, _ = make_theta_gamma_signal(n_items=min(n, 7), noise_level=0.6)
        bins, amp = compute_phase_amplitude_relationship(sig)
        pac_str.append(amp.max() - amp.min())
 
    pac_arr = np.array(pac_str)
    colors  = [ITEM_COLORS[min(i, len(ITEM_COLORS)-1)] for i in range(len(loads))]
    ax_load.bar(loads, pac_arr, color=colors, alpha=0.80, linewidth=0)
    ax_load.axvline(7.5, color='black', linewidth=1.5, linestyle='--',
                    alpha=0.6, label="Miller's limit (7±2)")
    ax_load.set_xticks(loads)
    ax_load.legend(fontsize=7, facecolor=BG, edgecolor=BORDER)
    ax_load.text(0.62, 0.88, "Capacity limit\n= γ cycles / θ cycle",
                 color=DIM, fontsize=7.5, fontfamily='monospace',
                 transform=ax_load.transAxes)
 
 
