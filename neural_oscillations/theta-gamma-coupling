# ── constants ─────────────────────────────────────────────────────────────────
FS         = 1000
T_TOTAL    = 2.0
T_AXIS     = np.linspace(0, T_TOTAL, int(FS * T_TOTAL))
THETA_FREQ = 6.0    # Hz — typical hippocampal theta
GAMMA_FREQ = 50.0   # Hz — gamma carrier
 
 
def make_theta_gamma_signal(n_items=4, noise_level=0.8):
    """
    Generate theta-gamma coupled signal.
    Each theta cycle contains n_items gamma bursts at specific phases.
    The gamma bursts represent distinct memory items being held active.
    """
    rng = np.random.default_rng(seed=n_items * 13)
    t   = T_AXIS
    n   = len(t)
 
    # theta carrier
    theta = np.sin(2 * np.pi * THETA_FREQ * t)
 
    # gamma amplitude modulated by theta phase
    # bursts at specific theta phases, one per item
    gamma_component = np.zeros(n)
 
    theta_period = 1.0 / THETA_FREQ   # seconds per theta cycle
    n_cycles     = int(T_TOTAL * THETA_FREQ)
 
    for cycle in range(n_cycles):
        cycle_start = cycle * theta_period
        for item in range(n_items):
            # each item fires at a specific phase within the theta cycle
            phase_offset = item / n_items   # 0 to 1 within cycle
            burst_t      = cycle_start + phase_offset * theta_period
            burst_idx    = int(burst_t * FS)
            burst_len    = int(0.020 * FS)   # 20ms gamma burst
 
            if burst_idx + burst_len < n:
                t_burst    = t[burst_idx:burst_idx + burst_len] - burst_t
                amplitude  = 3.5 * np.exp(-t_burst ** 2 / (2 * 0.008 ** 2))
                phase_rand = rng.uniform(0, 2 * np.pi)
                gamma_component[burst_idx:burst_idx + burst_len] += (
                    amplitude * np.sin(2 * np.pi * GAMMA_FREQ * t_burst + phase_rand)
                )
 
    # combine theta envelope + gamma + noise
    theta_envelope = (1 + 0.5 * theta) * 2   # theta modulates gamma amplitude
    signal = (
        3.0 * theta +
        gamma_component +
        rng.normal(0, noise_level, n)
    )
 
    return signal, theta, gamma_component
 
 
def compute_pac_comodulogram(sig, fs=FS, n_phase_bins=18):
    """
    Phase-Amplitude Coupling comodulogram.
    For each (phase_freq, amplitude_freq) pair, compute the
    mean amplitude of the high-freq signal at each phase of
    the low-freq signal. Strong coupling = clear modulation.
    Uses the mean vector length (MVL) method — Canolty 2006.
    """
    phase_freqs = np.arange(2, 20, 2)     # 2-18 Hz
    amp_freqs   = np.arange(20, 100, 5)   # 20-95 Hz
    pac_matrix  = np.zeros((len(amp_freqs), len(phase_freqs)))
 
    for i, pf in enumerate(phase_freqs):
        b_p, a_p = scipy_signal.butter(3, [pf - 1, pf + 1], btype='bandpass', fs=fs)
        phase_sig = scipy_signal.filtfilt(b_p, a_p, sig)
        phase     = np.angle(scipy_signal.hilbert(phase_sig))
 
        for j, af in enumerate(amp_freqs):
            b_a, a_a = scipy_signal.butter(3, [af - 4, af + 4], btype='bandpass', fs=fs)
            amp_sig  = scipy_signal.filtfilt(b_a, a_a, sig)
            amp      = np.abs(scipy_signal.hilbert(amp_sig))
            # MVL: how much does amplitude cluster at a particular phase
            mvl      = np.abs(np.mean(amp * np.exp(1j * phase)))
            pac_matrix[j, i] = mvl
 
    return phase_freqs, amp_freqs, pac_matrix
 
 
def compute_phase_amplitude_relationship(sig, fs=FS, n_bins=36):
    """
    Sort gamma amplitude by theta phase — the direct visualization
    of coupling. Shows that gamma peaks at a specific theta phase.
    """
    # extract theta phase
    b_t, a_t = scipy_signal.butter(4, [4, 8], btype='bandpass', fs=fs)
    theta_filt = scipy_signal.filtfilt(b_t, a_t, sig)
    theta_phase = np.angle(scipy_signal.hilbert(theta_filt))
 
    # extract gamma amplitude
    b_g, a_g = scipy_signal.butter(4, [30, 70], btype='bandpass', fs=fs)
    gamma_filt = scipy_signal.filtfilt(b_g, a_g, sig)
    gamma_amp  = np.abs(scipy_signal.hilbert(gamma_filt))
 
    # bin gamma amplitude by theta phase
    phase_bins = np.linspace(-np.pi, np.pi, n_bins + 1)
    amp_by_phase = np.zeros(n_bins)
    for k in range(n_bins):
        mask = (theta_phase >= phase_bins[k]) & (theta_phase < phase_bins[k + 1])
        if mask.sum() > 0:
            amp_by_phase[k] = gamma_amp[mask].mean()
 
    bin_centers = (phase_bins[:-1] + phase_bins[1:]) / 2
    return bin_centers, amp_by_phase
 
 
